# Firebase project config — get these from the Firebase console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENTID=

# Firebase App Check — reCAPTCHA v3 site key from Google reCAPTCHA console
VITE_RECAPTCHA_SITE_KEY=

# Set to "true" when running against the Firebase Emulator Suite locally.
# Must be "false" (or unset) in production.
VITE_USE_EMULATORS=true

# App Check debug token — generated by the Firebase SDK in debug mode.
# Only needed locally when USE_EMULATORS is true. Never set in production.
VITE_APPCHECK_DEBUG_TOKEN=
